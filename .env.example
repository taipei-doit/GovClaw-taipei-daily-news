# ===== 必填:每日生產線實際使用 =====

# LINE 官方帳號 Channel Access Token(每日 LINE 廣播用)
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here

# 主要配音 (TTS) 走 Google Vertex AI,使用 Application Default Credentials,
# 不需在此填金鑰。請先執行一次:
#   gcloud auth application-default login

# GCP 專案 ID(選填;未設定時自動取用 gcloud ADC 的預設專案)
# GCP_PROJECT_ID=your_gcp_project_id_here

# 專案工作目錄(選填;預設為本專案根目錄)
# TW_GOV_VIDEO_BASE=/path/to/repo


# ===== 選填:僅實驗 / 非生產線腳本使用 (experiments/) =====
# 正式每日流程不需要以下金鑰,維持註解即可。
# YATING_TTS_API_KEY=your_yating_tts_api_key_here
# ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
